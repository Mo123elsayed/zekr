{
  "categories": [
    {"id": "evening", "title": "أذكار المساء"}
  ],
  "azkar": [
    {"id": 1, "category_id": "evening", "text": "أَمْسَيْنَا وَأَمْسَى الْمُلْكُ لِلَّهِ وَالْحَمْدُ لِلَّهِ", "repeat": 1, "virtue": "رواه البخاري"},
    {"id": 2, "category_id": "evening", "text": "اللَّهُمَّ بِكَ أَمْسَيْنَا وَبِكَ أَصْبَحْنَا", "repeat": 1, "virtue": "رواه مسلم"},
    {"id": 3, "category_id": "evening", "text": "اللَّهُمَّ مَا أَمْسَى بِي مِنْ نِعْمَةٍ فَمِنْكَ", "repeat": 1, "virtue": "رواه الترمذي"},
    {"id": 4, "category_id": "evening", "text": "اللَّهُمَّ عَافِنِي فِي بَدَنِي", "repeat": 3, "virtue": "رواه مسلم"},
    {"id": 5, "category_id": "evening", "text": "اللَّهُمَّ إِنِّي أَمْسَيْتُ أُشْهِدُكَ", "repeat": 4, "virtue": "رواه أبو داود"},
    {"id": 6, "category_id": "evening", "text": "اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ", "repeat": 1, "virtue": "آية الكرسي"},
    {"id": 7, "category_id": "evening", "text": "قُلْ هُوَ اللَّهُ أَحَدٌ", "repeat": 3, "virtue": "الإخلاص"},
    {"id": 8, "category_id": "evening", "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ", "repeat": 3, "virtue": "الفلق"},
    {"id": 9, "category_id": "evening", "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ", "repeat": 3, "virtue": "الناس"},
    {"id": 10, "category_id": "evening", "text": "بِسْمِ اللَّهِ الَّذِي لاَ يَضُرُّ مَعَ اسْمِهِ شَيْءٌ", "repeat": 3, "virtue": "رواه أبو داود"},
    {"id": 11, "category_id": "evening", "text": "اللَّهُمَّ عَالِمَ الْغَيْبِ وَالشَّهَادَةِ", "repeat": 1, "virtue": "رواه البخاري"},
    {"id": 12, "category_id": "evening", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ عِلْمًا نَافِعًا", "repeat": 3, "virtue": "رواه ابن ماجه"},
    {"id": 13, "category_id": "evening", "text": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ", "repeat": 7, "virtue": "رواه البخاري"},
    {"id": 14, "category_id": "evening", "text": "آمَنَ الرَّسُولُ بِمَا أُنزِلَ إِلَيْهِ", "repeat": 1, "virtue": "آخر البقرة"},
    {"id": 15, "category_id": "evening", "text": "اللَّهُمَّ قُهْ جِيبِي وَجَانِبِي مِنَ النَّارِ", "repeat": 1, "virtue": "حماية"},
    {"id": 16, "category_id": "evening", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ", "repeat": 1, "virtue": "عافية"},
    {"id": 17, "category_id": "evening", "text": "اللَّهُمَّ بَارِكْ لِي فِي رِزْقِي", "repeat": 1, "virtue": "الرزق"},
    {"id": 18, "category_id": "evening", "text": "اللَّهُمَّ احْفَظْنِي مِنْ بَيْنِ يَدَيَّ", "repeat": 1, "virtue": "حفظ"},
    {"id": 19, "category_id": "evening", "text": "يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ", "repeat": 1, "virtue": "إغاثة"},
    {"id": 20, "category_id": "evening", "text": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ عَدَدَ خَلْقِهِ", "repeat": 3, "virtue": "الميزان"},
    {"id": 21, "category_id": "evening", "text": "اللَّهُمَّ اغْفِرْ لِي ذَنْبِي", "repeat": 1, "virtue": "مغفرة"},
    {"id": 22, "category_id": "evening", "text": "اللَّهُمَّ اجْعَلْنِي مِنَ التَّوَّابِينَ", "repeat": 1, "virtue": "التوبة"},
    {"id": 23, "category_id": "evening", "text": "رَبِّ أَعُوذُ بِكَ مِنْ هَمَازَةِ", "repeat": 3, "virtue": "حماية"},
    {"id": 24, "category_id": "evening", "text": "اللَّهُمَّ احْفَظْ أَهْلِي", "repeat": 1, "virtue": "الأهل"},
    {"id": 25, "category_id": "evening", "text": "اللَّهُمَّ اكْفِنِي بِحَلَالِكَ", "repeat": 1, "virtue": "الغنى"},
    {"id": 26, "category_id": "evening", "text": "أَعُوذُ بِكَلِمَاتِ اللَّهِ", "repeat": 3, "virtue": "حماية"},
    {"id": 27, "category_id": "evening", "text": "بِسْمِ اللَّهِ الَّذِي لاَ يَضُرُّ", "repeat": 3, "virtue": "حماية"},
    {"id": 28, "category_id": "evening", "text": "اللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ", "repeat": 10, "virtue": "الصلاة"},
    {"id": 29, "category_id": "evening", "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا", "repeat": 7, "virtue": "الدعاء"},
    {"id": 30, "category_id": "evening", "text": "سُبْحَانَ اللَّهِ", "repeat": 100, "virtue": "يومي"},
    {"id": 31, "category_id": "evening", "text": "الْحَمْدُ لِلَّهِ", "repeat": 100, "virtue": "يومي"}
  ]
}
