{
  "categories": [
    {"id": "deceased", "title": "أدعية للميت"}
  ],
  "azkar": [
    {"id": 1, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ", "repeat": 1, "virtue": "مسلم"},
    {"id": 2, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ وَآمِنْهُ مِنْ عَذَابِ الْقَبْرِ", "repeat": 1, "virtue": "مسلم"},
    {"id": 3, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ وَعَافِهِ وَاعْفُ عَنْهُ وَأَكْرِمْ نُزُلَهُ", "repeat": 1, "virtue": "مسلم الدفن"},
    {"id": 4, "category_id": "deceased", "text": "اللَّهُمَّ عَبْدُكَ وَابْنُ عَبْدِكَ حَاجَةُ إِلَيْكَ", "repeat": 1, "virtue": "أبو داود"},
    {"id": 5, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ وَآمِنْهُ مِنْ عَذَابِ جَهَنَّمَ", "repeat": 1, "virtue": "البخاري"},
    {"id": 6, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ وَأَسْعِدْهُ", "repeat": 1, "virtue": "مسلم"},
    {"id": 7, "category_id": "deceased", "text": "اللَّهُمَّ اغْسِلْهُ بِالْمَاءِ وَالثَّلْجِ وَالْبَرَدِ", "repeat": 1, "virtue": "الكامل"},
    {"id": 8, "category_id": "deceased", "text": "اللَّهُمَّ أَبْدِلْهُ دَارًا خَيْرًا مِنْ دَارِهِ", "repeat": 1, "virtue": "البخاري"},
    {"id": 9, "category_id": "deceased", "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً", "repeat": 7, "virtue": "البقرة"},
    {"id": 10, "category_id": "deceased", "text": "اللَّهُمَّ اجْعَلْ قَبْرَهُ رَوْضَةً", "repeat": 1, "virtue": "أحمد"},
    {"id": 11, "category_id": "deceased", "text": "اللَّهُمَّ سَلِّمْ لَهُ يَوْمَ الْفِرَاقِ", "repeat": 1, "virtue": "ابن ماجه"},
    {"id": 12, "category_id": "deceased", "text": "اللَّهُمَّ لَا تَحْرِمْنَا أَجْرَهُ", "repeat": 1, "virtue": "مسلم"},
    {"id": 13, "category_id": "deceased", "text": "اللَّهُمَّ ارْحَمْهُ بِرَحْمَتِكَ الْوَاسِعَةِ", "repeat": 1, "virtue": "شامل"},
    {"id": 14, "category_id": "deceased", "text": "اللَّهُمَّ ثَبِّتْهُ عَلَى الْإِيمَانِ", "repeat": 1, "virtue": "التثبيت"},
    {"id": 15, "category_id": "deceased", "text": "اللَّهُمَّ اجْعَلْ قَبْرَهُ وَاسِعًا مُنِيرًا", "repeat": 1, "virtue": "القبر"},
    {"id": 16, "category_id": "deceased", "text": "اللَّهُمَّ إِنَّهُ فِي رَحْمَتِكَ", "repeat": 1, "virtue": "الطبراني"},
    {"id": 17, "category_id": "deceased", "text": "إِنَّا لِلَّهِ وَإِنَّ إِلَيْهِ رَاجِعُونَ", "repeat": 1, "virtue": "البقرة"},
    {"id": 18, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لِحَيِّنَا وَمَيِّتِنَا", "repeat": 1, "virtue": "شامل"},
    {"id": 19, "category_id": "deceased", "text": "اللَّهُمَّ لَكَ حَمْدٌ لَا مُنْتَهَى لَهُ", "repeat": 1, "virtue": "المصيبة"},
    {"id": 20, "category_id": "deceased", "text": "اللَّهُمَّ ارْحَمْنِي بِرَحْمَتِكَ الْعَظِيمَةِ", "repeat": 1, "virtue": "رحمة"},
    {"id": 21, "category_id": "deceased", "text": "اللَّهُمَّ إِنَّ فُلَانَ فِي ذِمَّتِكَ", "repeat": 1, "virtue": "الإسلام"},
    {"id": 22, "category_id": "deceased", "text": "اللَّهُمَّ وَسِّعْ لَهُ قَبْرَهُ", "repeat": 1, "virtue": "توسيع"},
    {"id": 23, "category_id": "deceased", "text": "اللَّهُمَّ اجْعَلْهُ مَعَ النَّبِيِّينَ", "repeat": 1, "virtue": "رفقة"},
    {"id": 24, "category_id": "deceased", "text": "رَبَّنَا اتِنَا مِنْ لَدُنْكَ رَحْمَةً", "repeat": 1, "virtue": "الكهف"},
    {"id": 25, "category_id": "deceased", "text": "اللَّهُمَّ اغْفِرْ لَنَا وَلَهُ وَلِجَمِيعِ الْمُسْلِمِينَ", "repeat": 1, "virtue": "عام"}
  ]
}
