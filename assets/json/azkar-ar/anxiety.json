{
  "categories": [
    {"id": "anxiety", "title": "أذكار الهم والحزن"}
  ],
  "azkar": [
    {"id": 1, "category_id": "anxiety", "text": "لاَ إِلَهَ إِلاَّ اللَّهُ الْعَظِيمُ الْحَلِيمُ لاَ إِلَهَ إِلاَّ اللَّهُ رَبُّ الْعَرْشِ الْعَظِيمِ", "repeat": 1, "virtue": "رواه البخاري للهم"},
    {"id": 2, "category_id": "anxiety", "text": "اللَّهُمَّ رَحْمَنَ الدُّنْيَا وَالآخِرَةِ وَرَحِيمَهُمَا ارْحَمْنِي رَحْمَةً تَغْنِينِي", "repeat": 1, "virtue": "الترمذي"},
    {"id": 3, "category_id": "anxiety", "text": "يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ أَصْلِحْ لِي شَأْنِي كُلَّهُ", "repeat": 7, "virtue": "البخاري"},
    {"id": 4, "category_id": "anxiety", "text": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ", "repeat": 7, "virtue": "البخاري"},
    {"id": 5, "category_id": "anxiety", "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الآخِرَةِ حَسَنَةً", "repeat": 7, "virtue": "البقرة"},
    {"id": 6, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْهَمِّ وَالْحَزَنِ وَالْعَجْزِ", "repeat": 1, "virtue": "البخاري"},
    {"id": 7, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْهُدَى وَالتُّقَى وَالْعَفَافَ", "repeat": 1, "virtue": "مسلم"},
    {"id": 8, "category_id": "anxiety", "text": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ", "repeat": 100, "virtue": "البخاري"},
    {"id": 9, "category_id": "anxiety", "text": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ عَدَدَ خَلْقِهِ", "repeat": 3, "virtue": "مسلم"},
    {"id": 10, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ سَعَةً فِي الرِّزْقِ", "repeat": 1, "virtue": "الفرج"},
    {"id": 11, "category_id": "anxiety", "text": "اللَّهُمَّ لاَ سَهْلَ إِلاَّ مَا جَعَلْتَهُ سَهْلاً", "repeat": 7, "virtue": "ابن حبان"},
    {"id": 12, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَبْتَغِي مِنْكَ الْهُدَى وَالتُّقَى", "repeat": 1, "virtue": "مسلم"},
    {"id": 13, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَافِيَةَ", "repeat": 1, "virtue": "مسلم"},
    {"id": 14, "category_id": "anxiety", "text": "اللَّهُمَّ فَرِّجْ هَمِّي", "repeat": 1, "virtue": "الفرج"},
    {"id": 15, "category_id": "anxiety", "text": "اللَّهُمَّ أَنْتَ سَلِيَّتِي فِي نَوَائِبِ الْحَوَادِثِ", "repeat": 1, "virtue": "أبو داود"},
    {"id": 16, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْجَنَّةَ", "repeat": 1, "virtue": "البخاري"},
    {"id": 17, "category_id": "anxiety", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ رِضَاكَ", "repeat": 1, "virtue": "الرضا"},
    {"id": 18, "category_id": "anxiety", "text": "اللَّهُمَّ اكْفِنِي بِحَلَالِكَ عَنْ حَرَامِكَ", "repeat": 1, "virtue": "الترمذي"}
  ]
}
