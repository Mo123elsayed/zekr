{
  "categories": [
    {"id": "morning", "title": "أذكار الصباح"}
  ],
  "azkar": [
    {"id": 1, "category_id": "morning", "text": "أَصْبَحْنَا وَأَصْبَحَ الْمُلْكُ لِلَّهِ وَالْحَمْدُ لِلَّهِ", "repeat": 1, "virtue": "رواه البخاري"},
    {"id": 2, "category_id": "morning", "text": "اللَّهُمَّ بِكَ أَصْبَحْنَا وَبِكَ أَمْسَيْنَا", "repeat": 1, "virtue": "رواه مسلم"},
    {"id": 3, "category_id": "morning", "text": "اللَّهُمَّ مَا أَصْبَحَ بِي مِنْ نِعْمَةٍ فَمِنْكَ", "repeat": 1, "virtue": "رواه الترمذي"},
    {"id": 4, "category_id": "morning", "text": "اللَّهُمَّ عَافِنِي فِي بَدَنِي", "repeat": 3, "virtue": "رواه مسلم"},
    {"id": 5, "category_id": "morning", "text": "اللَّهُمَّ إِنِّي أَصْبَحْتُ أُشْهِدُكَ", "repeat": 4, "virtue": "رواه أبو داود"},
    {"id": 6, "category_id": "morning", "text": "اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ", "repeat": 1, "virtue": "آية الكرسي"},
    {"id": 7, "category_id": "morning", "text": "قُلْ هُوَ اللَّهُ أَحَدٌ", "repeat": 3, "virtue": "الإخلاص"},
    {"id": 8, "category_id": "morning", "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ", "repeat": 3, "virtue": "الفلق"},
    {"id": 9, "category_id": "morning", "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ", "repeat": 3, "virtue": "الناس"},
    {"id": 10, "category_id": "morning", "text": "بِسْمِ اللَّهِ الَّذِي لاَ يَضُرُّ مَعَ اسْمِهِ شَيْءٌ", "repeat": 3, "virtue": "رواه أبو داود"},
    {"id": 11, "category_id": "morning", "text": "اللَّهُمَّ عَالِمَ الْغَيْبِ وَالشَّهَادَةِ", "repeat": 1, "virtue": "رواه البخاري"},
    {"id": 12, "category_id": "morning", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ عِلْمًا نَافِعًا", "repeat": 3, "virtue": "رواه ابن ماجه"},
    {"id": 13, "category_id": "morning", "text": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ", "repeat": 7, "virtue": "رواه البخاري"},
    {"id": 14, "category_id": "morning", "text": "اللَّهُمَّ قُهْ جِيبِي وَجَانِبِي مِنَ النَّارِ", "repeat": 1, "virtue": "حماية"},
    {"id": 15, "category_id": "morning", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ", "repeat": 1, "virtue": "عافية"},
    {"id": 16, "category_id": "morning", "text": "اللَّهُمَّ بَارِكْ لِي فِي رِزْقِي", "repeat": 1, "virtue": "الرزق"},
    {"id": 17, "category_id": "morning", "text": "اللَّهُمَّ احْفَظْنِي مِنْ بَيْنِ يَدَيَّ وَمِنْ خَلْفِي", "repeat": 1, "virtue": "حفظ شامل"},
    {"id": 18, "category_id": "morning", "text": "يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ", "repeat": 1, "virtue": "رواه الحاكم"},
    {"id": 19, "category_id": "morning", "text": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ عَدَدَ خَلْقِهِ", "repeat": 3, "virtue": "يملأ الميزان"},
    {"id": 20, "category_id": "morning", "text": "اللَّهُمَّ اغْفِرْ لِي ذَنْبِي كُلَّهُ", "repeat": 1, "virtue": "مغفرة"},
    {"id": 21, "category_id": "morning", "text": "اللَّهُمَّ اجْعَلْنِي مِنَ التَّوَّابِينَ", "repeat": 1, "virtue": "التوبة"},
    {"id": 22, "category_id": "morning", "text": "رَبِّ أَعُوذُ بِكَ مِنْ هَمَازَةِ مَشَّاءٍ", "repeat": 3, "virtue": "المعارج"},
    {"id": 23, "category_id": "morning", "text": "اللَّهُمَّ احْفَظْ أَهْلِي وَذُرِّيَّتِي", "repeat": 1, "virtue": "الأهل"},
    {"id": 24, "category_id": "morning", "text": "اللَّهُمَّ اكْفِنِي بِحَلَالِكَ", "repeat": 1, "virtue": "الترمذي"},
    {"id": 25, "category_id": "morning", "text": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ", "repeat": 1, "virtue": "تكرار"},
    {"id": 26, "category_id": "morning", "text": "أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّاتِ", "repeat": 3, "virtue": "رواه مسلم"},
    {"id": 27, "category_id": "morning", "text": "بِسْمِ اللَّهِ الَّذِي لاَ يَضُرُّ مَعَ اسْمِهِ", "repeat": 3, "virtue": "تكرار"},
    {"id": 28, "category_id": "morning", "text": "اللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ", "repeat": 10, "virtue": "الترمذي"},
    {"id": 29, "category_id": "morning", "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً", "repeat": 7, "virtue": "البقرة"}
  ]
}
