{
  "categories": [
    {"id": "ruqyah", "title": "أذكار الرقية الشرعية"}
  ],
  "azkar": [
    {"id": 1, "category_id": "ruqyah", "text": "بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ", "repeat": 1, "virtue": "مسلم"},
    {"id": 2, "category_id": "ruqyah", "text": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ", "repeat": 7, "virtue": "الفاتحة"},
    {"id": 3, "category_id": "ruqyah", "text": "اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ", "repeat": 3, "virtue": "آية الكرسي"},
    {"id": 4, "category_id": "ruqyah", "text": "قُلْ هُوَ اللَّهُ أَحَدٌ", "repeat": 3, "virtue": "الإخلاص"},
    {"id": 5, "category_id": "ruqyah", "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ", "repeat": 3, "virtue": "الفلق"},
    {"id": 6, "category_id": "ruqyah", "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ", "repeat": 3, "virtue": "الناس"},
    {"id": 7, "category_id": "ruqyah", "text": "آمَنَ الرَّسُولُ بِمَا أُنزِلَ إِلَيْهِ", "repeat": 3, "virtue": "آخر البقرة"},
    {"id": 8, "category_id": "ruqyah", "text": "أَعُوذُ بِاللَّهِ مِنَ الشَّيْطَانِ الرَّجِيمِ", "repeat": 3, "virtue": "العياذ"},
    {"id": 9, "category_id": "ruqyah", "text": "حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ", "repeat": 7, "virtue": "الكرب"},
    {"id": 10, "category_id": "ruqyah", "text": "لَا حَوْلَ وَلَا قُوَّةَ إِلَّا بِاللَّهِ", "repeat": 100, "virtue": "كنز الجنة"},
    {"id": 11, "category_id": "ruqyah", "text": "بِسْمِ اللَّهِ الَّذِي لاَ يَضُرُّ مَعَ اسْمِهِ شَيْءٌ", "repeat": 3, "virtue": "أبو داود"},
    {"id": 12, "category_id": "ruqyah", "text": "أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّاتِ", "repeat": 3, "virtue": "مسلم"},
    {"id": 13, "category_id": "ruqyah", "text": "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ عَدَدَ خَلْقِهِ", "repeat": 3, "virtue": "مسلم"},
    {"id": 14, "category_id": "ruqyah", "text": "اللَّهُمَّ رَبَّ النَّاسِ مُذْهِبَ الْبَأْسِ اشْفِ", "repeat": 7, "virtue": "شفاء"},
    {"id": 15, "category_id": "ruqyah", "text": "اللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ وَآلِ مُحَمَّدٍ", "repeat": 10, "virtue": "الترمذي"},
    {"id": 16, "category_id": "ruqyah", "text": "يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ", "repeat": 3, "virtue": "النسائي"},
    {"id": 17, "category_id": "ruqyah", "text": "سُبْحَانَ اللَّهِ وَالْحَمْدُ لِلَّهِ وَلَا إِلَهَ إِلَّا اللَّهُ", "repeat": 33, "virtue": "مسلم"},
    {"id": 18, "category_id": "ruqyah", "text": "اللَّهُمَّ أَذْهِبِ الْبَأْسَ رَبَّ النَّاسِ", "repeat": 7, "virtue": "أبو داود"},
    {"id": 19, "category_id": "ruqyah", "text": "رَبِّيَ أَعُوذُ بِكَ مِنْ هَمَازَةِ مَشَّاءٍ", "repeat": 3, "virtue": "المعارج"},
    {"id": 20, "category_id": "ruqyah", "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَافِيَةَ", "repeat": 3, "virtue": "الترمذي"},
    {"id": 21, "category_id": "ruqyah", "text": "حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ", "repeat": 7, "virtue": "آل عمران"}
  ]
}
